---
import BaseLayout from './BaseLayout.astro';
import SideBar from '../components/ui/SideBar.astro';
import '../styles/docslayout.css';
---

<BaseLayout>
  <section class="docs-section" aria-label="Docs section">
    <nav aria-label="Navigazione componenti" class="docs-side">
      <SideBar />
    </nav>
    <article class="docs-article">
      <slot />
    </article>
  </section>
</BaseLayout>
